# 🧱 Crompressor: Pesquisa - GitIgnore
# Bloquear tudo por padrão e habilitar apenas o necessário (White-listing)

# 🚫 Ignorar tudo recursivamente
*

# ✅ Permitir arquivos de configuração e scripts
!.gitignore
!*.sh
!*.md
!scripts/

# ✅ Permitir subpastas de teste (apenas a estrutura e arquivos MD)
!01-logs_redundancia/
!02-delta_sync_cdc/
!03-vfs_mount_perf/
!04-p2p_soberania/
!05-tco_storage_frio/
!06-image_format_analysis/
!07-benchmark_comparativo/
!08-cloud_vfs_latency/
!09-p2p_dht_scale/
!10-entropy_shield/

# 🚫 Ignorar dados binários e logs dentro das pastas de teste
01-logs_redundancia/*
!01-logs_redundancia/*.md
02-delta_sync_cdc/*
!02-delta_sync_cdc/*.md
03-vfs_mount_perf/*
!03-vfs_mount_perf/*.md
04-p2p_soberania/*
!04-p2p_soberania/*.md
05-tco_storage_frio/*
!05-tco_storage_frio/*.md
06-image_format_analysis/*
!06-image_format_analysis/*.md
!06-image_format_analysis/scripts/
!06-image_format_analysis/scripts/*.sh

07-benchmark_comparativo/*
!07-benchmark_comparativo/*.md
!07-benchmark_comparativo/*.sh

# 🚫 Ignorar datasets reais (apenas README nestas pastas)
datasets/*
!datasets/*.md

# 🚫 Regras Pesquisas Cloud/P2P
08-cloud_vfs_latency/*
!08-cloud_vfs_latency/*.md
!08-cloud_vfs_latency/scripts/
!08-cloud_vfs_latency/scripts/*.sh

09-p2p_dht_scale/*
!09-p2p_dht_scale/*.md
!09-p2p_dht_scale/scripts/
!09-p2p_dht_scale/scripts/*.sh

10-entropy_shield/*
!10-entropy_shield/*.md
!10-entropy_shield/scripts/
!10-entropy_shield/scripts/*.sh

11-metamorphic_spawning/*
!11-metamorphic_spawning/*.md
!11-metamorphic_spawning/scripts/
!11-metamorphic_spawning/scripts/*.sh

12-v8_security_fuzzing/*
!12-v8_security_fuzzing/*.md
!12-v8_security_fuzzing/scripts/
!12-v8_security_fuzzing/scripts/*.sh

13-epigenetic_p2p_mesh/*
!13-epigenetic_p2p_mesh/*.md
!13-epigenetic_p2p_mesh/scripts/
!13-epigenetic_p2p_mesh/scripts/*.sh

# Temporários e Dumps
*.log
*.tmp
*.dat
.DS_Store

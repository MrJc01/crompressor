# ═══════════════════════════════════════════════════════
# 🧱 Crompressor: Pesquisa - GitIgnore (V26)
# ═══════════════════════════════════════════════════════

# ─── Diretórios de artefatos gerados (universais) ───
results/
brains/
datasets/
verify/

# ─── Artefatos binários e temporários ───
*.crom
*.cromdb
*.sqsh
*.bin
*.out
*.log
*.tmp
*.dat
*.zst
dummy*
*_output.bin

# ─── Preservar .gitkeep em diretórios vazios ───
!.gitkeep

# ─── Sempre rastrear scripts, código e docs ───
!**/*.sh
!**/*.go
!**/*.md
!**/*.html
!**/*.js
!**/utils.sh

# ─── Pesquisa: arquivos raiz essenciais ───
!run_all_audits.sh
!setup_pesquisa.sh
!index.md
!Manifesto.md
!web_audit_lab.html

# ─── LLM: ignorar binários e modelos pesados ───
ia_llm/102-native_llm_humble_pc/bin/
ia_llm/102-native_llm_humble_pc/models/

# ─── Scripts legados na raiz de /scripts ───
!scripts/run_benchmarks.sh
scripts/-
